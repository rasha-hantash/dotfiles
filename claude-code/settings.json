{
  "defaultMode": "acceptEdits",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "impeccable@impeccable": true,
    "ralph-loop@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "repo": "pbakaus/impeccable",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "afplay \"$HOME/.claude/assets/audio/beep.mp3\"",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "async": true,
            "command": "afplay \"$HOME/.claude/assets/audio/beep.mp3\"",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/git-guard.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "bash ~/.claude/hooks/auto-format.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "/Users/rashasaadeh/.cargo/bin/cove hook post-tool",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/pre-compact.py",
            "statusMessage": "Preserving context",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/branch-guard.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/validate-bash.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/worktree-guard.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "EnterWorktree"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "/Users/rashasaadeh/.cargo/bin/cove hook pre-tool",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "async": true,
            "command": "python3 ~/.claude/hooks/brain-os-capture.py",
            "timeout": 120,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "/Users/rashasaadeh/.cargo/bin/cove hook session-end",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/session-start.sh",
            "statusMessage": "Setting up environment",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "afplay \"$HOME/.claude/assets/audio/beep.mp3\"",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "/Users/rashasaadeh/.cargo/bin/cove hook stop",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "TaskCompleted": [],
    "TeammateIdle": [],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/brain-os-context.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "/Users/rashasaadeh/.cargo/bin/cove hook user-prompt",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "mcpServers": {
    "xactions": {
      "type": "http",
      "url": "https://modelcontextprotocol.name/mcp/xactions"
    }
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/CLAUDE.md)",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git tag *)",
      "Bash(git stash list)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(whoami)",
      "Bash(uname *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(uv *)",
      "Bash(python3 *)",
      "Bash(curl *)",
      "Bash(migrate *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(go *)",
      "Bash(bun *)",
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git add)",
      "Bash(git worktree *)",
      "Bash(git -C *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh pr create *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",
      "Bash(gh search *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(brew *)",
      "Bash(plutil *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cd *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__graphite__run_gt_cmd",
      "mcp__graphite__learn_gt",
      "Read",
      "Edit(~/workspace/personal/**)",
      "Edit(~/.claude/**)",
      "Write(~/workspace/personal/**)",
      "Write(~/.claude/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(chmod 777 *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(gh pr merge *)"
    ]
  },
  "statusLine": {
    "command": "bash $HOME/.claude/statusline-command.sh",
    "type": "command"
  },
  "voiceEnabled": false
}
