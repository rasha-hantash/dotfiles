{
  "mcpServers": {
    "mcp-debugger": {
      "command": "mcp-debugger",
      "args": ["stdio"],
      "env": {}
    },
    "mcp-js-debugger": {
      "command": "npx",
      "args": ["mcp-js-debugger"],
      "env": {}
    },
    "mcp-dap-server": {
      "command": "$HOME/workspace/personal/explorations/debugger/mcp-dap-server/bin/mcp-dap-server",
      "args": [],
      "env": {}
    },
    "arxiv-mcp-server": {
      "command": "uv",
      "args": ["tool", "run", "arxiv-mcp-server"],
      "env": {}
    },
    "technical-rag": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "$HOME/workspace/personal/explorations/technical-rag/mcp-server",
        "python",
        "-m",
        "technical_rag_mcp"
      ]
    }
  }
}
